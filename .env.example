# ── CEDX Tiny Agent Fleet — Environment Example ──────────────────────
# Copy to .env, fill in secrets, and the pipeline reads it automatically.

# Pipeline identity
CASE_ID=CEDX-0000
SEED_DIR=seed
PIPELINE_NOW=2026-06-26

# LLM mode: true = replay transcripts (offline), false = live API calls
REPLAY_LLM=true

# For live mode (REPLAY_LLM=false), configure one of these:

# --- Option A: OpenAI / OpenAI-compatible (Groq, OpenRouter, DeepSeek) ---
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
#
#   Groq (free):     LLM_BASE_URL=https://api.groq.com/openai/v1
#                    LLM_MODEL=llama-3.1-8b-instant
#   OpenRouter:      LLM_BASE_URL=https://openrouter.ai/api/v1
#                    LLM_MODEL=openai/gpt-4o-mini
#   DeepSeek:        LLM_BASE_URL=https://api.deepseek.com
#                    LLM_MODEL=deepseek-chat

# --- Option B: Google Gemini ---
# Requires google-genai SDK: pip install google-genai
# Sign up at https://aistudio.google.com/apikey (free tier)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# Budget
MAX_COST_USD_PER_RECORD=0.05
MAX_STEPS_PER_RECORD=10

# Detector tuning
OUTLIER_IQR_MULTIPLIER=3.0
